# Rate limiting
limit_req_zone $binary_remote_addr zone=general:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=api:10m rate=30r/s;

# Upstream para Laravel
upstream laravel_backend {
    server laravel:9000;
}

# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name nutridiario.com.br www.nutridiario.com.br;

    # Health check endpoint (sem redirect)
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    # Let's Encrypt webroot (sem redirect)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        try_files $uri =404;
    }

    # Temporariamente sem redirect para obter certificado SSL
    location / {
        return 200 "Aguardando configuração SSL\n";
        add_header Content-Type text/plain;
    }
}

